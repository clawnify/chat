{
  "name": "@clawnify/chat",
  "version": "0.0.1",
  "type": "module",
  "description": "Open-source chat UI for OpenClaw gateways.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawnify/chat.git"
  },
  "homepage": "https://github.com/clawnify/chat#readme",
  "bugs": "https://github.com/clawnify/chat/issues",
  "keywords": ["openclaw", "chat", "agent", "ai"],
  "bin": {
    "clawnify-chat": "bin/clawnify-chat.mjs"
  },
  "files": [
    "bin",
    "dist",
    "packaging",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "start": "node bin/clawnify-chat.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
